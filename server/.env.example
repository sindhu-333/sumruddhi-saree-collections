# Copy this file to .env and set real values before running the server.
# If your hosting provider exposes a DATABASE_URL, use it instead of individual PG_* vars.
DATABASE_URL=
PGHOST=localhost
PGPORT=5432
PGUSER=your_database_user
PGPASSWORD=your_database_password
PGDATABASE=saree_collections
JWT_SECRET=replace_with_a_long_random_secret
PORT=4000

# Email sender config
# Preferred: use a hosted mail provider API (Resend, Mailgun, Brevo, etc.)
MAIL_PROVIDER=resend
MAIL_API_URL=https://api.resend.com/emails
MAIL_API_KEY=your_mail_api_key
MAIL_FROM="Saree Collections <no-reply@yourdomain.com>"

# Fallback SMTP (only if you still want to use Gmail/SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ADMIN_NOTIFICATION_EMAIL=admin@example.com
FRONTEND_BASE_URL=http://localhost:3000
ADMIN_DEFAULT_PASSWORD=replace_with_a_strong_admin_password
